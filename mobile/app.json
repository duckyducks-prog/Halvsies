{
  "expo": {
    "name": "Halvsies",
    "slug": "halvsies",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon/icon-master-1024.png",
    "scheme": "halvsies",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundImage": "./assets/icon/adaptive-background-1024.png",
        "foregroundImage": "./assets/icon/adaptive-foreground-1024.png",
        "monochromeImage": "./assets/icon/adaptive-monochrome-1024.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/icon/icon-master-1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#26241F",
          "image": "./assets/icon/adaptive-foreground-1024.png",
          "imageWidth": 130
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
