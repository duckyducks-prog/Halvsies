# Copy this file to `.env` and fill in your Supabase project values.
# Found in Supabase dashboard → Project Settings → API.
# Leave these blank to run in local (single-device) mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (reminders + nudges). Public half of your VAPID key pair.
# Generate a pair with:  npx web-push generate-vapid-keys
# The PRIVATE key goes in Supabase Edge Function secrets, NOT here.
VITE_VAPID_PUBLIC_KEY=
